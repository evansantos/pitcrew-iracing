{
  "name": "iracing-race-engineer",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time iRacing race engineer application with telemetry analysis and strategy tools",
  "keywords": ["iracing", "telemetry", "racing", "motorsport", "strategy"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "type-check": "turbo type-check",
    "setup-ai": "./scripts/setup-ai.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
