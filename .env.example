# iRacing Race Engineer — Environment Configuration

# iRacing Mode
# Options: 'local' (direct SDK), 'remote' (relay server), 'mock' (simulated data)
IRACING_MODE=mock

# For remote mode, specify the relay server host (Windows machine running iRacing)
IRACING_RELAY_HOST=192.168.1.100
IRACING_RELAY_PORT=3002

# API Configuration
API_PORT=3001
NODE_ENV=development

# AI Configuration (Optional — requires Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
