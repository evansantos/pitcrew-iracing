# iRacing Mode
# Options: 'local' (direct SDK), 'remote' (relay server), 'mock' (simulated data)
IRACING_MODE=mock

# For remote mode, specify relay server details:
IRACING_RELAY_HOST=localhost
IRACING_RELAY_PORT=3002

# iRacing SDK Configuration
IRSDK_PATH=/path/to/iracing
TELEMETRY_RATE=60

# API Configuration
API_PORT=3000
NODE_ENV=development

# AI Configuration (Optional)
# Ollama base URL - use http://ollama:11434 for Docker, http://localhost:11434 for local
OLLAMA_BASE_URL=http://localhost:11434
# AI model to use (llama3.1:8b, phi3:mini, etc.)
OLLAMA_MODEL=llama3.1:8b

# Feature Flags
ENABLE_VOICE_ALERTS=true
ENABLE_TELEMETRY_RECORDING=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Monitoring (Optional)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Session Data
SESSION_DATA_PATH=session-data.json
