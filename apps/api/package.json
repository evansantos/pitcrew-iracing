{
  "name": "@iracing-race-engineer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify backend API for iRacing race engineer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "ai:status": "curl -s http://localhost:11434/api/tags | jq '.models[].name' || echo '❌ Ollama not running or jq not installed'",
    "ai:setup": "echo '🤖 Setting up AI Race Engineer...' && ollama pull llama3.1:8b",
    "ai:setup-lite": "echo '🤖 Setting up AI Race Engineer (lite)...' && ollama pull phi3:mini",
    "ai:serve": "echo '🤖 Starting Ollama server...' && ollama serve"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "@fastify/websocket": "^11.0.1",
    "@types/ws": "^8.18.1",
    "bullmq": "^5.28.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "node-irsdk": "^2.1.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
